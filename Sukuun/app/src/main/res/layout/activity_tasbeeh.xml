<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2C3333"
    android:padding="20dp">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Back"
        android:src="@android:drawable/ic_menu_revert"
        app:tint="#E7F6F2" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="10dp"
        android:fontFamily="serif"
        android:text="Tasbeeh"
        android:textColor="#E7F6F2"
        android:textSize="20sp" />

    <androidx.cardview.widget.CardView
        android:id="@+id/circleTapArea"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_centerInParent="true"
        app:cardBackgroundColor="#A5C9CA"
        app:cardCornerRadius="130dp"
        app:cardElevation="8dp">

        <TextView
            android:id="@+id/tvCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="0"
            android:textColor="#2C3333"
            android:textSize="70sp"
            android:textStyle="bold" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/circleTapArea"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="30dp"
        android:alpha="0.6"
        android:text="Tap circle to count • Hold to reset"
        android:textColor="#E7F6F2"
        android:textSize="14sp" />

</RelativeLayout>